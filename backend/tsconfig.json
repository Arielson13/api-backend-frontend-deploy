{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "rootDir": "./src",
    "outDir": "./dist",

    "moduleResolution": "node16",    
    "esModuleInterop": true,

    "strict": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,
    "sourceMap": true
  }
}